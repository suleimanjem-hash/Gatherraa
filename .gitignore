################################################################################
# Comprehensive .gitignore for monorepo (Frontend, Backend, Smart Contracts)  #
################################################################################

# ============================================================================
# PACKAGE MANAGERS - LOCK FILES
# ============================================================================
# NPM lock files SHOULD be committed for reproducible CI builds.
# Other lock files are workspace-level and should be regenerated during setup.
pnpm-lock.yaml
yarn.lock
Cargo.lock

# ============================================================================
# OTHER LOCK FILES
# ============================================================================
*.lock

# ============================================================================
# DEPENDENCIES - NODE MODULES
# ============================================================================
node_modules/
*/node_modules/
*/*/node_modules/
app/backend/node_modules/
app/frontend/node_modules/
app/image-service/node_modules/
contract/node_modules/
tests/node_modules/

# ============================================================================
# BUILD AND COMPILATION OUTPUTS
# ============================================================================
# Frontend builds
app/frontend/.next/
app/frontend/dist/
app/frontend/build/
app/frontend/out/
.vercel/

# Backend builds
app/backend/dist/
app/backend/build/

# Smart contract builds
contract/artifacts/
contract/cache/
contract/dist/
contract/build/
contract/*/target/
contract/typechain-types/
typechain-types/

# General build outputs
/dist
/build
/out
/bundle

# ============================================================================
# RUST BUILD ARTIFACTS
# ============================================================================
**/target/
**/.cargo/
Cargo.lock
**/test_snapshots/

# ============================================================================
# IDE AND EDITOR FILES
# ============================================================================
.vscode/
!.vscode/settings.json
!.vscode/tasks.json
!.vscode/launch.json
!.vscode/extensions.json
.idea/
.project
.classpath
.c9/
*.launch
.settings/
*.sublime-workspace
*.swp
*.swo
*~
.editorconfig.local

# ============================================================================
# OS AND SYSTEM FILES
# ============================================================================
.DS_Store
.DS_Store?
._*
.Spotlight-V100
.Trashes
ehthumbs.db
Thumbs.db
desktop.ini

# ============================================================================
# TESTING AND COVERAGE
# ============================================================================
coverage/
.nyc_output/
lcov.info
*.lcov
.jest-cache/
test-results/
.vitest/

# ============================================================================
# LOGS (NEVER COMMIT)
# ============================================================================
*.log
logs/
log/
npm-debug.log*
pnpm-debug.log*
yarn-debug.log*
yarn-error.log*
lerna-debug.log*
*.out

# ============================================================================
# ENVIRONMENT FILES (SECRETS - NEVER COMMIT)
# ============================================================================
.env
.env.local
.env.development
.env.development.local
.env.test
.env.test.local
.env.production
.env.production.local
.env.*.local
.env.vault

# ============================================================================
# TEMPORARY AND CACHE FILES
# ============================================================================
.temp/
.tmp/
tmp/
temp/
*.tmp
*.bak
*.backup
*.swp
*.swo
*~
.cache/
.eslintcache
.browserslistrc.cache

# ============================================================================
# RUNTIME DATA AND DATABASES
# ============================================================================
pids/
*.pid
*.seed
*.pid.lock
*.sqlite
*.sqlite3
*.db
*.db-shm
*.db-wal

# ============================================================================
# DIAGNOSTIC AND REPORTING
# ============================================================================
report.[0-9]*.[0-9]*.[0-9]*.[0-9]*.json
dump.rdb
*.stackdump
perf-results/

# ============================================================================
# VSCODE SPECIFIC
# ============================================================================
.vscode-test/
.vscode-remote/

# ============================================================================
# GENERATED FILES
# ============================================================================
next-env.d.ts
*.tsbuildinfo
*.js.map
*.ts.map

# ============================================================================
# DOCKER
# ============================================================================
.docker/
docker.env

